      let activeImportJobId = null;
      let activeImportInterval = null;

      async function cancelCloudImport() {
        if (activeImportInterval) { clearInterval(activeImportInterval); activeImportInterval = null; }
        if (activeImportJobId) {
          try { await fetch(`/api/videos/import/${activeImportJobId}`, { method: 'DELETE' }); } catch (e) {}
          activeImportJobId = null;
        }
        hideBottomBar();
        showToast('warning', 'Import cancelled');
      }

      async function cancelActiveOperation() {
        if (activeXHR || activeAbortController) {
          await cancelUpload();
        } else if (activeImportJobId) {
          await cancelCloudImport();
        }
      }

      function showImportProgress(jobId, providerName) {
        activeImportJobId = jobId;
        showBottomBar(`Importing from ${providerName || 'cloud'}...`);
        const bb = document.getElementById('bottomProgressBar');
        const bp = document.getElementById('bottomProgressPercent');
        if (bb) bb.style.width = '0%';
        if (bp) bp.textContent = '0%';

        activeImportInterval = setInterval(async () => {
          if (!activeImportJobId || activeImportJobId !== jobId) { clearInterval(activeImportInterval); return; }
          try {
            const response = await fetch(`/api/videos/import-status/${jobId}`);
            const data = await response.json();
            if (!data.success) { clearInterval(activeImportInterval); activeImportInterval = null; activeImportJobId = null; hideBottomBar(); return; }
            const status = data.status;
            if (bb) bb.style.width = `${status.progress}%`;
            if (bp) bp.textContent = `${status.progress}%`;
            const bs = document.getElementById('bottomUploadStatus');
            if (bs) bs.textContent = status.message;
            if (status.status === 'complete') {
              clearInterval(activeImportInterval); activeImportInterval = null; activeImportJobId = null;
              hideBottomBar();
              showToast('success', 'Video imported successfully');
              setTimeout(() => reloadKeepingFolder(), 1500);
            } else if (status.status === 'failed') {
              clearInterval(activeImportInterval); activeImportInterval = null; activeImportJobId = null;
              hideBottomBar();
              showToast('error', status.message || 'Import failed');
            } else if (status.status === 'skipped') {
              clearInterval(activeImportInterval); activeImportInterval = null; activeImportJobId = null;
              hideBottomBar();
              showToast('warning', status.message || 'Format is not supported, import skipped');
            } else if (status.status === 'cancelled') {
              clearInterval(activeImportInterval); activeImportInterval = null; activeImportJobId = null;
              hideBottomBar();
            }
          } catch (e) { console.error(e); }
        }, 1000);
      }

      // ============================================================
      // UPLOAD (chunked / simple / audio) — unchanged from original
      // ============================================================
      let selectedFiles = [];
      const CHUNK_SIZE = 50 * 1024 * 1024;
      const MAX_RETRIES = 3;
      const RETRY_DELAY_MS = 1000;

      // Upload cancellation state
      let activeXHR = null;
      let activeAbortController = null;
      let activeUploadId = null;
      let uploadCancelled = false;

      function showBottomBar(statusText) {
        const bar = document.getElementById('bottomUploadBar');
        if (bar) bar.classList.remove('hidden');
        const s = document.getElementById('bottomUploadStatus');
        if (s) s.textContent = statusText || 'Uploading...';
      }

      function hideBottomBar() {
        const bar = document.getElementById('bottomUploadBar');
        if (bar) bar.classList.add('hidden');
      }

      async function cancelUpload() {
        uploadCancelled = true;
        if (activeXHR) { activeXHR.abort(); activeXHR = null; }
        if (activeAbortController) { activeAbortController.abort(); activeAbortController = null; }
        if (activeUploadId) {
          try { await fetch(`/api/videos/chunk/${activeUploadId}`, { method: 'DELETE' }); } catch (e) {}
          activeUploadId = null;
        }
        hideBottomBar();
        resetUploadForm();
      }

      const ALLOWED_AUDIO_EXTS = ['.mp3','.wav','.aac','.m4a','.ogg','.flac','.wma'];
      const ALLOWED_VIDEO_EXTS = ['.mp4','.avi','.mov','.webm'];

      function isAudioFile(file) {
        const audioTypes = ['audio/mpeg','audio/mp3','audio/wav','audio/x-wav','audio/aac','audio/mp4','audio/x-m4a','audio/ogg','audio/flac','audio/x-flac','audio/x-ms-wma','audio/wma'];
        const ext = '.' + file.name.split('.').pop().toLowerCase();
        return audioTypes.includes(file.type) || ALLOWED_AUDIO_EXTS.includes(ext);
      }
      function isVideoFile(file) {
        const videoTypes = ['video/mp4','video/avi','video/x-msvideo','video/quicktime','video/webm'];
        const ext = '.' + file.name.split('.').pop().toLowerCase();
        return videoTypes.includes(file.type) || ALLOWED_VIDEO_EXTS.includes(ext);
      }
      function isSupportedFile(file) {
        return isAudioFile(file) || isVideoFile(file);
      }

      // ============================================================
      // SEARCH / FILTER / SORT / PAGINATION
      // ============================================================
      let filteredGridItems = [];
      let filteredListItems = [];
      let currentPage = 1;
      const itemsPerPage = 18;

      function getItemData(item) {
        return {
          id: item.dataset.id,
          title: item.dataset.title || '',
          date: new Date(item.dataset.date || 0).getTime(),
          size: parseInt(item.dataset.size) || 0,
          type: item.dataset.type || 'video',
          folder: item.dataset.folder || ''
        };
      }

      function filterAndSort() {
        const search = document.getElementById('searchInput') ? document.getElementById('searchInput').value.toLowerCase() : '';
        const sort = document.getElementById('sortSelect') ? document.getElementById('sortSelect').value : 'newest';
        const type = document.getElementById('typeFilter') ? document.getElementById('typeFilter').value : 'all';

        const gridItems = document.querySelectorAll('.file-item');
        const listItems = document.querySelectorAll('.file-item-row');

        const filterFn = (item) => {
          const data = getItemData(item);
          // Must be in current folder
          const folderMatch = currentFolderId === null
            ? data.folder === ''
            : data.folder === String(currentFolderId);
          const matchesSearch = data.title.toLowerCase().includes(search);
          const matchesType = type === 'all' || data.type === type;
          return folderMatch && matchesSearch && matchesType;
        };

        const sortFn = (a, b) => {
          const dataA = getItemData(a);
          const dataB = getItemData(b);
          switch (sort) {
            case 'oldest': return dataA.date - dataB.date;
            case 'name': return dataA.title.localeCompare(dataB.title);
            case 'size': return dataB.size - dataA.size;
            default: return dataB.date - dataA.date;
          }
        };

        filteredGridItems = [...gridItems].filter(filterFn).sort(sortFn);
        filteredListItems = [...listItems].filter(filterFn).sort(sortFn);

        const gridContainer = document.getElementById('fileGridContainer');
        const listContainer = document.querySelector('#fileListBody');

        if (gridContainer) filteredGridItems.forEach(item => gridContainer.appendChild(item));
        if (listContainer) filteredListItems.forEach(item => listContainer.appendChild(item));

        currentPage = 1;
        renderPage();
      }

      function renderPage() {
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;

        document.querySelectorAll('.file-item').forEach(item => item.style.display = 'none');
        document.querySelectorAll('.file-item-row').forEach(item => item.style.display = 'none');

        filteredGridItems.slice(start, end).forEach(item => item.style.display = '');
        filteredListItems.slice(start, end).forEach(item => item.style.display = '');

        const totalItems = filteredGridItems.length;
        const info = document.getElementById('paginationInfo');
        if (info) info.textContent = totalItems > 0
          ? `Showing ${start + 1}-${Math.min(end, totalItems)} of ${totalItems} items`
          : 'No items found';

        renderPagination();
        updateBulkBar();
      }

      function renderPagination() {
        const container = document.getElementById('paginationControls');
        if (!container) return;
        const totalPages = Math.ceil(filteredGridItems.length / itemsPerPage);
        container.innerHTML = '';
        if (totalPages <= 1) return;

        const prev = document.createElement('button');
        prev.className = `w-9 h-9 flex items-center justify-center rounded-lg ${currentPage === 1 ? 'bg-dark-700 text-gray-600 cursor-not-allowed' : 'bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors'}`;
        prev.innerHTML = '<i class="ti ti-chevron-left"></i>';
        prev.disabled = currentPage === 1;
        prev.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); } });
        container.appendChild(prev);

        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, startPage + 4);
        if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
        for (let i = startPage; i <= endPage; i++) {
          const btn = document.createElement('button');
          btn.className = `w-9 h-9 flex items-center justify-center rounded-lg ${i === currentPage ? 'bg-primary text-white' : 'bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors'}`;
          btn.textContent = i;
          btn.addEventListener('click', () => { currentPage = i; renderPage(); });
          container.appendChild(btn);
        }

        const next = document.createElement('button');
        next.className = `w-9 h-9 flex items-center justify-center rounded-lg ${currentPage === totalPages ? 'bg-dark-700 text-gray-600 cursor-not-allowed' : 'bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors'}`;
        next.innerHTML = '<i class="ti ti-chevron-right"></i>';
        next.disabled = currentPage === totalPages;
        next.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; renderPage(); } });
        container.appendChild(next);
      }

      // ============================================================
      // DOMContentLoaded — wire up upload logic
      // ============================================================
      document.addEventListener('DOMContentLoaded', function () {

        // List view checkbox — capture phase mencegah <tr onclick> terpanggil
        const fileListBody = document.getElementById('fileListBody');
        if (fileListBody) {
          fileListBody.addEventListener('click', function (e) {
            const cb = e.target.closest('.file-checkbox');
            if (!cb) return;
            e.stopImmediatePropagation();
            e.stopPropagation();
          }, true);
          fileListBody.addEventListener('change', function (e) {
            const cb = e.target.closest('.file-checkbox');
            if (!cb) return;
            handleCheckboxChange(cb);
          });
        }

        const mediaFileInput = document.getElementById('mediaFileInput');
        const selectedFileInfo = document.getElementById('selectedFileInfo');
        const selectedFileCount = document.getElementById('selectedFileCount');
        const selectedFilesList = document.getElementById('selectedFilesList');
        const clearFileButton = document.getElementById('clearFileButton');
        const uploadDropzone = document.getElementById('uploadDropzone');
        const uploadButton = document.getElementById('uploadButton');
        const uploadProgress = document.getElementById('uploadProgress');
        const uploadProgressBar = document.getElementById('uploadProgressBar');
        const uploadProgressPercent = document.getElementById('uploadProgressPercent');
        const uploadProgressStatus = document.getElementById('uploadProgressStatus');
        const uploadFilesList = document.getElementById('uploadFilesList');

        if (mediaFileInput) {
          mediaFileInput.addEventListener('change', function () {
            const newFiles = Array.from(this.files);
            if (newFiles.length > 0) {
              const unsupported = newFiles.filter(f => !isSupportedFile(f));
              if (unsupported.length > 0) {
                const names = unsupported.map(f => f.name).join(', ');
                const isVideo = !document.getElementById('tabAudio')?.classList.contains('bg-primary');
                const hint = isVideo ? 'Only MP4, AVI, MOV, and WEBM files are supported.' : 'Only MP3, WAV, AAC, M4A, OGG, FLAC, and WMA files are supported.';
                showToast('warning', `Format is not supported: ${names}. ${hint}`);
                this.value = '';
                return;
              }
              const maxSize = 50 * 1024 * 1024 * 1024;
              const large = newFiles.filter(f => f.size > maxSize);
              if (large.length > 0) { showToast('error', `File too large: ${large.map(f => f.name).join(', ')}`); this.value = ''; return; }
              const totalNewSize = newFiles.reduce((sum, f) => sum + f.size, 0);
              const totalSelectedSize = selectedFiles.reduce((sum, f) => sum + f.size, 0);
              if (!checkDiskLimit(totalNewSize + totalSelectedSize)) { showToast('error', `Not enough server disk space. Available: ${formatFileSize(getRemainingSpace())}`); this.value = ''; return; }
              newFiles.forEach(f => { if (!selectedFiles.some(e => e.name === f.name && e.size === f.size)) selectedFiles.push(f); });
              updateFilesList();
              uploadDropzone.classList.add('hidden');
              selectedFileInfo.classList.remove('hidden');
              uploadButton.disabled = false;
            }
            this.value = '';
          });
        }

        function updateFilesList() {
          const totalSize = selectedFiles.reduce((sum, f) => sum + f.size, 0);
          selectedFileCount.textContent = `${selectedFiles.length} file${selectedFiles.length > 1 ? 's' : ''} selected (${formatFileSize(totalSize)})`;
          selectedFilesList.innerHTML = '';
          selectedFiles.forEach((file, i) => {
            const isAudio = isAudioFile(file);
            const icon = isAudio ? 'ti-music' : 'ti-video';
            const div = document.createElement('div');
            div.className = 'flex items-center justify-between p-2 rounded-lg hover:bg-dark-600 transition-colors';
            div.innerHTML = `
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-8 h-8 rounded bg-dark-600 flex items-center justify-center shrink-0">
                  <i class="ti ${icon} text-gray-400 text-sm"></i>
                </div>
                <div class="min-w-0">
                  <p class="text-sm truncate">${file.name}</p>
                  <p class="text-xs text-gray-500">${formatFileSize(file.size)}</p>
                </div>
              </div>
              <button type="button" class="text-gray-400 hover:text-red-400 p-1" data-index="${i}">
                <i class="ti ti-x text-sm"></i>
              </button>`;
            div.querySelector('button').addEventListener('click', () => {
              selectedFiles.splice(i, 1);
              if (selectedFiles.length > 0) updateFilesList();
              else resetUploadForm();
            });
            selectedFilesList.appendChild(div);
          });
        }

        if (clearFileButton) clearFileButton.addEventListener('click', resetUploadForm);

        if (uploadButton) {
          uploadButton.addEventListener('click', async function () {
            if (selectedFiles.length === 0) return;
            uploadCancelled = false;

            // Close modal immediately, show bottom bar
            document.getElementById('uploadModal').classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
            showBottomBar(`Uploading 1/${selectedFiles.length}: ${selectedFiles[0].name}`);

            let success = 0, failed = [], failedErrors = [];

            for (let i = 0; i < selectedFiles.length; i++) {
              if (uploadCancelled) break;
              const file = selectedFiles[i];
              const isAudio = isAudioFile(file);
              const statusText = `Uploading ${i + 1}/${selectedFiles.length}: ${file.name}`;
              const bStatus = document.getElementById('bottomUploadStatus');
              if (bStatus) bStatus.textContent = statusText;
              if (!checkDiskLimit(file.size)) {
                showToast('error', `Not enough server disk space to upload ${file.name}`);
                failed.push(file.name); failedErrors.push('Insufficient server disk space');
                continue;
              }
              const result = isAudio ? await uploadAudio(file, i, selectedFiles.length) : await uploadFile(file, i, selectedFiles.length);
              if (result.error === 'cancelled') break;
              if (result.success) { success++; }
              else { failed.push(file.name); failedErrors.push(result.error || 'Unknown error'); }
            }

            activeXHR = null; activeAbortController = null; activeUploadId = null;
            hideBottomBar();

            if (uploadCancelled) {
              showToast('warning', 'Upload cancelled');
              resetUploadForm();
              return;
            }

            if (failed.length === 0) showToast('success', `${success} file${success > 1 ? 's' : ''} uploaded successfully`);
            else if (failed.length === 1) showToast('warning', `Upload failed for "${failed[0]}": ${failedErrors[0] || ''}`);
            else showToast('warning', `${success} uploaded, ${failed.length} failed`);
            setTimeout(() => reloadKeepingFolder(), 2000);
          });
        }

        async function uploadFile(file, index, total) {
          return file.size > CHUNK_SIZE ? uploadChunked(file, index, total) : uploadSimple(file, index, total);
        }

        function updateProgress(index, total, loadedBytes, totalBytes, status) {
          const filePct = totalBytes > 0 ? Math.round((loadedBytes / totalBytes) * 100) : 0;
          const overall = Math.round(((index + loadedBytes / totalBytes) / total) * 100);
          uploadProgressBar.style.width = `${overall}%`;
          uploadProgressPercent.textContent = `${overall}%`;
          const bb = document.getElementById('bottomProgressBar');
          const bp = document.getElementById('bottomProgressPercent');
          if (bb) bb.style.width = `${overall}%`;
          if (bp) bp.textContent = `${overall}%`;
          updateFileProgress(index, status, filePct);
        }

        function updateFileProgress(index, status, percent) {
          const items = uploadFilesList.children;
          if (items[index]) {
            const el = items[index].querySelector('.file-status');
            if (status === 'uploading') { el.textContent = `${percent}%`; el.className = 'file-status text-xs text-primary'; }
            else if (status === 'success') { el.textContent = '✓'; el.className = 'file-status text-xs text-green-400'; }
            else if (status === 'error') { el.textContent = '✗'; el.className = 'file-status text-xs text-red-400'; }
          }
        }

        async function uploadAudio(file, index, total) {
          return new Promise((resolve) => {
            if (!file || !(file instanceof File)) return resolve({ success: false, error: 'File tidak valid' });
            const formData = new FormData();
            formData.append('audio', file);
            if (currentFolderId !== null) formData.append('folder_id', String(currentFolderId));
            const xhr = new XMLHttpRequest();
            activeXHR = xhr;
            xhr.timeout = Math.max(2, Math.ceil(file.size / (10 * 1024 * 1024))) * 60 * 1000;
            xhr.upload.addEventListener('progress', (e) => {
              if (!e.lengthComputable) return;
              const pct = Math.round((e.loaded / e.total) * 100);
              const overall = Math.round(((index + e.loaded / e.total) / total) * 100);
              if (uploadProgressBar) uploadProgressBar.style.width = `${overall}%`;
              if (uploadProgressPercent) uploadProgressPercent.textContent = `${overall}%`;
              const bb = document.getElementById('bottomProgressBar');
              const bp = document.getElementById('bottomProgressPercent');
              if (bb) bb.style.width = `${overall}%`;
              if (bp) bp.textContent = `${overall}%`;
              updateFileProgress(index, 'uploading', pct);
            });
            xhr.addEventListener('load', () => {
              activeXHR = null;
              if (xhr.status === 200) {
                try { const r = JSON.parse(xhr.responseText); resolve({ success: r.success, error: r.error || null }); }
                catch { resolve({ success: false, error: 'Parse error' }); }
              } else { resolve({ success: false, error: `HTTP ${xhr.status}` }); }
            });
            xhr.addEventListener('abort', () => { activeXHR = null; resolve({ success: false, error: 'cancelled' }); });
            xhr.addEventListener('error', () => { activeXHR = null; resolve({ success: false, error: 'Network error' }); });
            xhr.addEventListener('timeout', () => { activeXHR = null; resolve({ success: false, error: 'Timeout' }); });
            xhr.open('POST', '/api/audio/upload', true);
            xhr.send(formData);
          });
        }

        async function uploadSimple(file, index, total) {
          return new Promise((resolve) => {
            const formData = new FormData();
            formData.append('video', file);
            if (currentFolderId !== null) formData.append('folder_id', String(currentFolderId));
            const xhr = new XMLHttpRequest();
            activeXHR = xhr;
            xhr.timeout = 30 * 60 * 1000;
            xhr.upload.addEventListener('progress', (e) => { if (e.lengthComputable) updateProgress(index, total, e.loaded, e.total, 'uploading'); });
            xhr.addEventListener('load', () => {
              activeXHR = null;
              if (xhr.status === 200) {
                try { const r = JSON.parse(xhr.responseText); resolve({ success: r.success, error: r.error || null }); }
                catch { resolve({ success: false, error: 'Invalid server response' }); }
              } else { resolve({ success: false, error: `HTTP ${xhr.status}` }); }
            });
            xhr.addEventListener('abort', () => { activeXHR = null; resolve({ success: false, error: 'cancelled' }); });
            xhr.addEventListener('error', () => { activeXHR = null; resolve({ success: false, error: 'Network error' }); });
            xhr.addEventListener('timeout', () => { activeXHR = null; resolve({ success: false, error: 'Upload timed out' }); });
            xhr.open('POST', '/api/videos/upload', true);
            xhr.send(formData);
          });
        }

        async function uploadChunked(file, index, total) {
          const abortController = new AbortController();
          activeAbortController = abortController;
          const { signal } = abortController;

          let initData;
          try {
            const initResp = await fetch('/api/videos/chunk/init', {
              method: 'POST', signal,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ filename: file.name, fileSize: file.size, totalChunks: Math.ceil(file.size / CHUNK_SIZE) })
            });
            initData = await initResp.json();
            if (!initResp.ok || !initData.success) return { success: false, error: initData.error || `Init failed: HTTP ${initResp.status}` };
          } catch (e) {
            if (e.name === 'AbortError') return { success: false, error: 'cancelled' };
            return { success: false, error: `Init error: ${e.message}` };
          }

          const { uploadId } = initData;
          activeUploadId = uploadId;
          const serverChunkSize = initData.chunkSize || CHUNK_SIZE;
          const totalChunks = Math.ceil(file.size / serverChunkSize);
          let uploadedChunks = new Set(initData.uploadedChunks || []);

          for (let i = 0; i < totalChunks; i++) {
            if (signal.aborted) return { success: false, error: 'cancelled' };
            if (uploadedChunks.has(i)) { updateProgress(index, total, Math.min((i + 1) * serverChunkSize, file.size), file.size, 'uploading'); continue; }
            const start = i * serverChunkSize;
            const chunk = file.slice(start, Math.min(start + serverChunkSize, file.size));
            let success = false, lastError = null;
            for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {
              if (signal.aborted) return { success: false, error: 'cancelled' };
              try {
                const res = await fetch('/api/videos/chunk/upload', {
                  method: 'POST', signal,
                  headers: { 'Content-Type': 'application/octet-stream', 'X-Upload-Id': uploadId, 'X-Chunk-Index': String(i) },
                  body: chunk
                });
                if (!res.ok) { lastError = `HTTP ${res.status}`; throw new Error(lastError); }
                const data = await res.json();
                if (!data.success) { lastError = data.error || 'Chunk upload failed'; throw new Error(lastError); }
                uploadedChunks = new Set(data.uploadedChunks || []);
                success = true; break;
              } catch (e) {
                if (e.name === 'AbortError') return { success: false, error: 'cancelled' };
                lastError = e.message;
                if (attempt < MAX_RETRIES - 1) await new Promise(r => setTimeout(r, RETRY_DELAY_MS * (attempt + 1)));
              }
            }
            if (!success) { activeAbortController = null; activeUploadId = null; return { success: false, error: `Chunk ${i} gagal: ${lastError}` }; }
            updateProgress(index, total, Math.min((i + 1) * serverChunkSize, file.size), file.size, 'uploading');
          }

          if (signal.aborted) return { success: false, error: 'cancelled' };
          try {
            const completeResp = await fetch('/api/videos/chunk/complete', {
              method: 'POST', signal,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ uploadId, folder_id: currentFolderId !== null ? currentFolderId : null })
            });
            activeAbortController = null; activeUploadId = null;
            if (!completeResp.ok) return { success: false, error: `Complete failed: HTTP ${completeResp.status}` };
            const completeData = await completeResp.json();
            return { success: completeData.success, error: completeData.error || null };
          } catch (e) {
            activeAbortController = null; activeUploadId = null;
            if (e.name === 'AbortError') return { success: false, error: 'cancelled' };
            return { success: false, error: `Complete error: ${e.message}` };
          }
        }

        if (uploadDropzone) {
          uploadDropzone.addEventListener('click', (e) => { if (!e.target.closest('label')) mediaFileInput.click(); });
          uploadDropzone.addEventListener('dragenter', (e) => { e.preventDefault(); uploadDropzone.classList.add('border-primary', 'bg-primary/5'); });
          uploadDropzone.addEventListener('dragover', (e) => { e.preventDefault(); });
          uploadDropzone.addEventListener('dragleave', (e) => { e.preventDefault(); uploadDropzone.classList.remove('border-primary', 'bg-primary/5'); });
          uploadDropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadDropzone.classList.remove('border-primary', 'bg-primary/5');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
              const validFiles = Array.from(files).filter(f => currentUploadType === 'video' ? isVideoFile(f) : isAudioFile(f));
              if (validFiles.length > 0) {
                validFiles.forEach(f => { if (!selectedFiles.some(e => e.name === f.name && e.size === f.size)) selectedFiles.push(f); });
                updateFilesList();
                uploadDropzone.classList.add('hidden');
                selectedFileInfo.classList.remove('hidden');
                uploadButton.disabled = false;
              } else {
                if (currentUploadType === 'video') showToast('error', 'Please upload a valid video file');
                else showToast('error', 'Please upload a valid audio file');
              }
            }
          });
        }

        // Wire up filter/sort
        const searchInput = document.getElementById('searchInput');
        const sortSelect = document.getElementById('sortSelect');
        const typeFilter = document.getElementById('typeFilter');
        if (searchInput) searchInput.addEventListener('input', filterAndSort);
        if (sortSelect) sortSelect.addEventListener('change', filterAndSort);
        if (typeFilter) typeFilter.addEventListener('change', filterAndSort);

        // Initial render
        filterAndSort();
      });
    </script>

    <style>
      * { scrollbar-width: thin; scrollbar-color: rgba(156,163,175,0.3) transparent; }
      ::-webkit-scrollbar { width: 5px; height: 5px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background-color: rgba(156,163,175,0.3); border-radius: 20px; }
      ::-webkit-scrollbar-thumb:hover { background-color: rgba(156,163,175,0.5); }
      .audio-visualizer { animation: pulse 2s ease-in-out infinite; }
      @keyframes pulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.05); opacity: 0.8; } }

      /* Always show checkbox on checked state */
      .file-checkbox:checked ~ * { opacity: 1; }
      .file-item.ring-2 .checkbox-wrapper { opacity: 1 !important; }
    </style>
