<% layout('layout') -%>
  <% function formatFileSize(bytes) { if (!bytes || bytes===0) return '0 B' ; bytes=Number(bytes); if (isNaN(bytes))
    return '0 B' ; if (bytes < 1024) return bytes + ' B' ; else if (bytes < 1048576) return (bytes / 1024).toFixed(1)
    + ' KB' ; else if (bytes < 1073741824) return (bytes / 1048576).toFixed(1) + ' MB' ; else if (bytes < 1099511627776)
    return (bytes / 1073741824).toFixed(2) + ' GB' ; else return (bytes / 1099511627776).toFixed(2) + ' TB' ; } function
    formatDuration(seconds) { if (!seconds) return '0:00' ; const hours=Math.floor(seconds / 3600); const
    minutes=Math.floor((seconds % 3600) / 60); const secs=Math.floor(seconds % 60); if (hours> 0) return
    `${hours}:${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    return `${minutes}:${secs.toString().padStart(2, '0')}`;
    } function formatResolution(res) { if (!res) return ''; const m = res.match(/^(\d+)[xX×](\d+)$/); if (!m) return res; const h = parseInt(m[2]); if (h >= 2160) return '4K'; if (h >= 1440) return '1440p'; if (h >= 1080) return '1080p'; if (h >= 720) return '720p'; if (h >= 480) return '480p'; if (h >= 360) return '360p'; return h + 'p'; } %>

    <div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
      <div>
        <h2 class="text-2xl font-bold">Media Gallery</h2>
        <p class="text-gray-400 text-sm mt-1">
          <span>Manage your videos and audio for streaming</span>
          <span id="diskUsageInfoDesktop" class="hidden">
            <span class="text-gray-500 mx-1">•</span>
            <i class="ti ti-database text-xs"></i>
            <span id="diskUsageTextDesktop" class="text-gray-400"></span>
          </span>
        </p>
        <p id="diskUsageInfoMobile" class="hidden text-gray-400 text-sm mt-1">
          <i class="ti ti-database text-xs mr-1"></i>
          <span id="diskUsageTextMobile"></span>
        </p>
      </div>
      <div class="flex gap-3 flex-wrap">
        <button onclick="openCreateFolderModal()"
          class="flex items-center gap-2 bg-dark-700 border border-gray-600 hover:bg-dark-600 text-white px-4 py-2 rounded-lg transition-colors">
          <i class="ti ti-folder-plus"></i>
          <span>New Folder</span>
        </button>
        <button onclick="openUploadModal()"
          class="flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors">
          <i class="ti ti-upload"></i>
          <span>Upload Media</span>
        </button>
        <div class="relative">
          <button onclick="toggleCloudDropdown()"
            class="flex items-center gap-2 bg-dark-700 border border-gray-600 hover:bg-dark-600 text-white px-4 py-2 rounded-lg transition-colors">
            <i class="ti ti-cloud-download"></i>
            <span>Import from Cloud</span>
            <i class="ti ti-chevron-down text-sm"></i>
          </button>
          <div id="cloudDropdown"
            class="hidden absolute right-0 mt-2 w-48 bg-dark-800 border border-gray-700 rounded-lg shadow-xl z-50">
            <button onclick="openCloudModal('gdrive')"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors rounded-t-lg">
              <img src="/images/google drive.png" alt="Google Drive" class="w-5 h-5">
              <span>Google Drive</span>
            </button>
            <button onclick="openCloudModal('mediafire')"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors">
              <img src="/images/mediafire.png" alt="Mediafire" class="w-5 h-5">
              <span>Mediafire</span>
            </button>
            <button onclick="openCloudModal('dropbox')"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors">
              <img src="/images/dropbox.png" alt="Dropbox" class="w-5 h-5">
              <span>Dropbox</span>
            </button>
            <button onclick="openCloudModal('mega')"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors rounded-b-lg">
              <img src="/images/mega.png" alt="MEGA" class="w-5 h-5">
              <span>MEGA</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Breadcrumb -->
    <div id="breadcrumb" class="flex items-center gap-1.5 mb-4 text-sm text-gray-400 flex-wrap">
      <button onclick="navigateToFolder(null)" class="hover:text-white transition-colors flex items-center gap-1">
        <i class="ti ti-home text-xs"></i>
        <span>Root</span>
      </button>
      <!-- breadcrumb items injected by JS -->
    </div>

    <div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 border-b border-gray-700 gap-4">
        <div class="flex items-center gap-3 flex-wrap">
          <div class="relative w-full sm:w-64">
            <input type="text" id="searchInput" placeholder="Search videos..."
              class="w-full bg-dark-700 border border-gray-600 text-white pl-9 pr-4 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
            <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
          </div>
          <select id="typeFilter"
            class="bg-dark-700 border border-gray-600 text-white px-3 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
            <option value="all">All Media</option>
            <option value="video">Video</option>
            <option value="audio">Audio</option>
          </select>
          <select id="sortSelect"
            class="bg-dark-700 border border-gray-600 text-white px-3 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
            <option value="name">Name</option>
            <option value="size">Size</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <!-- Bulk action bar -->
          <div id="bulkActionBar" class="hidden items-center gap-2 flex-wrap">
            <span id="selectedCount" class="text-sm text-gray-400 mr-1"></span>
            <button onclick="bulkMoveSelected()"
              class="flex items-center gap-1.5 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm rounded-lg transition-colors">
              <i class="ti ti-folder-symlink"></i>
              <span>Move Selected</span>
            </button>
            <button onclick="bulkCopySelected()"
              class="flex items-center gap-1.5 px-3 py-2 bg-green-600 hover:bg-green-700 text-white text-sm rounded-lg transition-colors">
              <i class="ti ti-copy"></i>
              <span>Copy Selected</span>
            </button>
            <button onclick="deleteSelected()"
              class="flex items-center gap-1.5 px-3 py-2 bg-red-600 hover:bg-red-700 text-white text-sm rounded-lg transition-colors">
              <i class="ti ti-trash"></i>
              <span>Delete Selected</span>
            </button>
            <button onclick="clearSelection()"
              class="flex items-center gap-1.5 px-3 py-2 bg-dark-700 hover:bg-dark-600 text-gray-300 text-sm rounded-lg transition-colors" title="Clear selection">
              <i class="ti ti-x"></i>
            </button>
          </div>
          <!-- Select All button — selalu tampil -->
          <button id="selectAllBtn" onclick="selectAll()"
            class="flex items-center gap-1.5 px-3 py-2 bg-dark-700 border border-gray-600 hover:bg-dark-600 text-gray-300 text-sm rounded-lg transition-colors" title="Select all">
            <i class="ti ti-checks"></i>
            <span class="hidden sm:inline">Select All</span>
          </button>
          <div class="flex items-center bg-dark-700 border border-gray-600 rounded-lg overflow-hidden">
            <button id="gridViewBtn" class="px-3 py-2 bg-primary text-white" title="Grid view">
              <i class="ti ti-layout-grid"></i>
            </button>
            <button id="listViewBtn" class="px-3 py-2 text-gray-400 hover:text-white transition-colors"
              title="List view">
              <i class="ti ti-list"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="p-4">
        <!-- Folder + file grid view -->
        <div id="gridView">
          <!-- Folders row -->
          <div id="folderGridContainer" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 gap-2 mb-4"></div>
          <!-- Files grid -->
          <% if (videos && videos.length > 0) { %>
            <div id="fileGridContainer" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
              <% videos.forEach(function(video) {
                const isAudio = video.filepath && (video.filepath.includes('/audio/') ||
                  video.filepath.endsWith('.m4a') || video.filepath.endsWith('.aac') || video.filepath.endsWith('.mp3'));
                const mediaType = isAudio ? 'audio' : 'video'; %>
                <div
                  class="file-item group bg-dark-700 rounded-lg overflow-hidden border border-transparent hover:border-gray-600 hover:bg-dark-600 transition-all cursor-pointer relative"
                  data-id="<%= video.id %>"
                  data-title="<%= video.title %>"
                  data-date="<%= video.upload_date %>"
                  data-size="<%= video.file_size %>"
                  data-type="<%= mediaType %>"
                  data-folder="<%= video.folder_id || '' %>"
                  onclick="handleFileClick(event, '<%= video.id %>', '<%= video.title %>', '<%= mediaType %>')">

                  <!-- Checkbox -->
                  <div class="absolute top-2 left-2 z-10 checkbox-wrapper opacity-0 group-hover:opacity-100 transition-opacity"
                    onclick="event.stopPropagation()">
                    <input type="checkbox" class="file-checkbox w-4 h-4 accent-primary cursor-pointer rounded"
                      data-id="<%= video.id %>" data-title="<%= video.title %>"
                      onchange="handleCheckboxChange(this)">
                  </div>

                  <div class="aspect-video relative overflow-hidden bg-dark-900">
                    <% if (isAudio) { %>
                      <div class="w-full h-full flex items-center justify-center bg-[#181818]">
                        <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center">
                          <i class="ti ti-music text-3xl text-primary"></i>
                        </div>
                      </div>
                    <% } else { %>
                      <img src="<%= video.thumbnail_path %>" alt="<%= video.title %>" class="w-full h-full object-cover">
                    <% } %>
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                      <div class="bg-primary/90 w-10 h-10 rounded-full flex items-center justify-center">
                        <i class="ti ti-player-play-filled text-white"></i>
                      </div>
                    </div>
                    <span class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-1.5 py-0.5 rounded">
                      <%= formatDuration(video.duration) %>
                    </span>
                    <% if (isAudio) { %>
                      <span class="absolute top-2 right-2 bg-primary/80 text-white text-xs px-1.5 py-0.5 rounded">
                        <i class="ti ti-music text-xs mr-1"></i>Audio
                      </span>
                    <% } %>
                  </div>
                  <div class="p-3">
                    <h3 class="font-medium text-sm truncate mb-1"><%= video.title %></h3>
                    <div class="flex items-center justify-between">
                      <span class="text-xs text-gray-400"><%= formatFileSize(video.file_size) %><span class="hidden sm:inline"><% if (!isAudio && video.resolution) { %> • <%= formatResolution(video.resolution) %><% } %><% if (!isAudio && video.fps) { %> • <%= video.fps %> fps<% } %></span></span>
                      <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        <button class="text-gray-400 hover:text-blue-400 p-1" title="Move to folder"
                          onclick="event.stopPropagation(); openMoveModal('<%= video.id %>', '<%= video.title %>', 'move')">
                          <i class="ti ti-folder-symlink text-sm"></i>
                        </button>
                        <button class="text-gray-400 hover:text-green-400 p-1" title="Copy to folder"
                          onclick="event.stopPropagation(); openMoveModal('<%= video.id %>', '<%= video.title %>', 'copy')">
                          <i class="ti ti-copy text-sm"></i>
                        </button>
                        <button class="text-gray-400 hover:text-white p-1"
                          onclick="event.stopPropagation(); showRenameDialog('<%= video.id %>', '<%= video.title %>')">
                          <i class="ti ti-pencil text-sm"></i>
                        </button>
                        <button class="text-gray-400 hover:text-red-400 p-1"
                          onclick="event.stopPropagation(); showDeleteDialog('<%= video.id %>', '<%= video.title %>')">
                          <i class="ti ti-trash text-sm"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div id="emptyState" class="text-center py-12">
              <div class="w-16 h-16 rounded-full bg-dark-700 flex items-center justify-center mx-auto mb-4">
                <i class="ti ti-video text-gray-500 text-2xl"></i>
              </div>
              <h3 class="text-lg font-medium text-gray-300 mb-2">No videos yet</h3>
              <p class="text-gray-500 text-sm mb-4">Upload your first video to get started</p>
              <button onclick="openUploadModal()"
                class="inline-flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors">
                <i class="ti ti-upload"></i>
                <span>Upload Video</span>
              </button>
            </div>
          <% } %>
        </div>

        <!-- List view -->
        <div id="listView" class="hidden">
          <!-- Folders list -->
          <div id="folderListContainer" class="mb-2"></div>
          <!-- Files list -->
          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead class="bg-gray-700">
                <tr>
                  <th class="px-4 py-3 text-left w-8">
                    <input type="checkbox" id="selectAllCheckbox" class="w-4 h-4 accent-primary cursor-pointer rounded"
                      title="Select / Deselect All"
                      onclick="this.checked ? selectAll() : clearSelection()">
                  </th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Name</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-24">Duration</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Size</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-32">Modified</th>
                  <th class="px-4 py-3 text-right text-xs font-medium text-gray-300 uppercase tracking-wider w-32">Actions</th>
                </tr>
              </thead>
              <tbody id="fileListBody" class="divide-y divide-gray-700">
                <% if (videos && videos.length > 0) { %>
                  <% videos.forEach(function(video) {
                    const isAudio = video.filepath && (video.filepath.includes('/audio/') ||
                      video.filepath.endsWith('.m4a') || video.filepath.endsWith('.aac') || video.filepath.endsWith('.mp3'));
                    const mediaType = isAudio ? 'audio' : 'video'; %>
                    <tr class="file-item-row group hover:bg-dark-700 transition-colors cursor-pointer"
                      data-id="<%= video.id %>"
                      data-title="<%= video.title %>"
                      data-date="<%= video.upload_date %>"
                      data-size="<%= video.file_size %>"
                      data-type="<%= mediaType %>"
                      data-folder="<%= video.folder_id || '' %>"
                      onclick="handleFileClick(event, '<%= video.id %>', '<%= video.title %>', '<%= mediaType %>')">
                      <td class="px-4 py-3">
                        <input type="checkbox" class="file-checkbox w-4 h-4 accent-primary cursor-pointer rounded"
                          data-id="<%= video.id %>" data-title="<%= video.title %>">
                      </td>
                      <td class="px-4 py-3">
                        <div class="flex items-center gap-3">
                          <div class="w-12 h-8 rounded overflow-hidden bg-[#181818] flex-shrink-0 relative flex items-center justify-center">
                            <% if (isAudio) { %>
                              <i class="ti ti-music text-primary"></i>
                            <% } else { %>
                              <img src="<%= video.thumbnail_path %>" alt="" class="w-full h-full object-cover">
                            <% } %>
                          </div>
                          <span class="font-medium text-sm truncate max-w-xs"><%= video.title %></span>
                        </div>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-400"><%= formatDuration(video.duration) %></td>
                      <td class="px-4 py-3 text-sm text-gray-400"><%= formatFileSize(video.file_size) %><span class="hidden sm:inline"><% if (!isAudio && video.resolution) { %> • <%= formatResolution(video.resolution) %><% } %><% if (!isAudio && video.fps) { %> • <%= video.fps %> fps<% } %></span></td>
                      <td class="px-4 py-3 text-sm text-gray-400"><%= new Date(video.upload_date).toLocaleDateString() %></td>
                      <td class="px-4 py-3 text-right">
                        <div class="flex items-center justify-end gap-1">
                          <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-blue-400 transition-colors" title="Move"
                            onclick="event.stopPropagation(); openMoveModal('<%= video.id %>', '<%= video.title %>', 'move')">
                            <i class="ti ti-folder-symlink text-sm"></i>
                          </button>
                          <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-green-400 transition-colors" title="Copy"
                            onclick="event.stopPropagation(); openMoveModal('<%= video.id %>', '<%= video.title %>', 'copy')">
                            <i class="ti ti-copy text-sm"></i>
                          </button>
                          <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-white transition-colors"
                            onclick="event.stopPropagation(); showRenameDialog('<%= video.id %>', '<%= video.title %>')">
                            <i class="ti ti-pencil text-sm"></i>
                          </button>
                          <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-red-400 transition-colors"
                            onclick="event.stopPropagation(); showDeleteDialog('<%= video.id %>', '<%= video.title %>')">
                            <i class="ti ti-trash text-sm"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% if (videos && videos.length > 0) { %>
        <div class="px-4 py-3 border-t border-gray-700 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p id="paginationInfo" class="text-sm text-gray-400">Showing 1-<%= Math.min(videos.length, 24) %> of <%= videos.length %> videos</p>
          <div id="paginationControls" class="flex items-center gap-2"></div>
        </div>
      <% } %>
    </div>

    <!-- ==================== FOLDER MODALS ==================== -->

    <!-- Create Folder Modal -->
    <div id="createFolderModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
      <div class="bg-dark-800 rounded-lg shadow-xl w-full max-w-sm border border-gray-600/50">
        <div class="flex items-center justify-between p-4 border-b border-gray-700">
          <h3 class="text-lg font-semibold flex items-center gap-2"><i class="ti ti-folder-plus text-primary"></i> New Folder</h3>
          <button onclick="closeCreateFolderModal()" class="text-gray-400 hover:text-white"><i class="ti ti-x text-xl"></i></button>
        </div>
        <div class="p-5">
          <label class="block text-sm font-medium text-gray-300 mb-2">Folder Name</label>
          <input type="text" id="newFolderName" placeholder="Enter folder name"
            class="w-full bg-dark-700 border border-gray-600 text-white px-3 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        </div>
        <div class="flex justify-end gap-3 p-4 border-t border-gray-700">
          <button onclick="closeCreateFolderModal()" class="px-4 py-2 bg-dark-700 hover:bg-dark-600 text-gray-300 rounded-lg transition-colors">Cancel</button>
          <button onclick="createFolder()" class="px-4 py-2 bg-primary hover:bg-blue-600 text-white rounded-lg transition-colors">Create</button>
        </div>
      </div>
    </div>

    <!-- Rename Folder Modal -->
    <div id="renameFolderModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
      <div class="bg-dark-800 rounded-lg shadow-xl w-full max-w-sm border border-gray-600/50">
        <div class="flex items-center justify-between p-4 border-b border-gray-700">
          <h3 class="text-lg font-semibold flex items-center gap-2"><i class="ti ti-pencil text-primary"></i> Rename Folder</h3>
          <button onclick="closeRenameFolderModal()" class="text-gray-400 hover:text-white"><i class="ti ti-x text-xl"></i></button>
        </div>
        <div class="p-5">
          <input type="hidden" id="renameFolderId">
          <label class="block text-sm font-medium text-gray-300 mb-2">New Name</label>
          <input type="text" id="renameFolderName" placeholder="Enter new folder name"
            class="w-full bg-dark-700 border border-gray-600 text-white px-3 py-2 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary">
        </div>
        <div class="flex justify-end gap-3 p-4 border-t border-gray-700">
          <button onclick="closeRenameFolderModal()" class="px-4 py-2 bg-dark-700 hover:bg-dark-600 text-gray-300 rounded-lg transition-colors">Cancel</button>
          <button onclick="renameFolder()" class="px-4 py-2 bg-primary hover:bg-blue-600 text-white rounded-lg transition-colors">Rename</button>
        </div>
      </div>
    </div>

    <!-- Move / Copy Modal -->
    <div id="moveModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
      <div class="bg-dark-800 rounded-lg shadow-xl w-full max-w-sm border border-gray-600/50">
        <div class="flex items-center justify-between p-4 border-b border-gray-700">
          <h3 id="moveModalTitle" class="text-lg font-semibold"></h3>
          <button onclick="closeMoveModal()" class="text-gray-400 hover:text-white"><i class="ti ti-x text-xl"></i></button>
        </div>
        <div class="p-5">
          <input type="hidden" id="moveFileId">
          <input type="hidden" id="moveAction">
          <p class="text-sm text-gray-400 mb-3">Select destination folder:</p>
          <div id="folderPickerList" class="space-y-2 max-h-60 overflow-y-auto">
            <!-- Populated by JS -->
          </div>
        </div>
        <div class="flex justify-end gap-3 p-4 border-t border-gray-700">
          <button onclick="closeMoveModal()" class="px-4 py-2 bg-dark-700 hover:bg-dark-600 text-gray-300 rounded-lg transition-colors">Cancel</button>
          <button onclick="confirmMoveFile()" id="moveConfirmBtn" class="px-4 py-2 bg-primary hover:bg-blue-600 text-white rounded-lg transition-colors">Confirm</button>
        </div>
      </div>
    </div>

    <!-- ==================== ORIGINAL MODALS ==================== -->

    <div id="uploadModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden modal-overlay overflow-y-auto">
      <div class="flex min-h-screen items-center justify-center p-4">
        <div class="bg-dark-800 rounded-lg shadow-xl w-full max-w-lg" id="uploadModalContent">
          <div class="flex items-center justify-between p-4 border-b border-gray-700">
            <h3 class="text-lg font-semibold">Upload Media</h3>
            <button onclick="closeUploadModal()" class="text-gray-400 hover:text-white">
              <i class="ti ti-x text-xl"></i>
            </button>
          </div>
          <div class="p-6">
            <div class="flex gap-2 mb-4">
              <button type="button" id="tabVideo"
                class="flex-1 py-2 px-4 rounded-lg bg-primary text-white transition-colors"
                onclick="switchUploadTab('video')">
                <i class="ti ti-video mr-2"></i>Video
              </button>
              <button type="button" id="tabAudio"
                class="flex-1 py-2 px-4 rounded-lg bg-dark-700 text-gray-400 hover:text-white transition-colors"
                onclick="switchUploadTab('audio')">
                <i class="ti ti-music mr-2"></i>Audio
              </button>
            </div>
            <form id="videoUploadForm" enctype="multipart/form-data">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="uploadType" id="uploadType" value="video">
              <div id="uploadDropzone"
                class="border-2 border-dashed border-gray-600 hover:border-primary rounded-lg py-10 px-6 text-center transition-all cursor-pointer"
                data-state="idle">
                <div class="flex flex-col items-center justify-center space-y-3">
                  <div class="w-14 h-14 rounded-full bg-dark-700 flex items-center justify-center">
                    <i id="dropzoneIcon" class="ti ti-cloud-upload text-2xl text-gray-400"></i>
                  </div>
                  <div>
                    <p id="dropzoneText" class="text-gray-300">Drag and drop video files here</p>
                    <p class="text-gray-500 text-sm">Or click to browse</p>
                  </div>
                  <label
                    class="bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors inline-block cursor-pointer">
                    <span>Select files</span>
                    <input type="file" name="media"
                      accept="video/mp4,video/avi,video/x-msvideo,video/quicktime,video/webm,.mp4,.avi,.mov,.webm"
                      multiple class="hidden" id="mediaFileInput">
                  </label>
                  <p id="dropzoneFormats" class="text-gray-500 text-xs">Supported formats: MP4, AVI, MOV, and WEBM (max 50GB)</p>
                </div>
              </div>
              <div id="selectedFileInfo" class="hidden">
                <div class="bg-dark-700 p-4 rounded-lg">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
                        <i class="ti ti-files text-primary"></i>
                      </div>
                      <div>
                        <p class="font-medium text-sm">Selected files</p>
                        <p id="selectedFileCount" class="text-xs text-gray-400"></p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <button type="button" class="text-primary hover:text-blue-400 text-sm"
                        onclick="document.getElementById('mediaFileInput').click()">Add more</button>
                      <button type="button" id="clearFileButton" class="text-gray-400 hover:text-white p-1">
                        <i class="ti ti-x"></i>
                      </button>
                    </div>
                  </div>
                  <div id="selectedFilesList" class="space-y-2 max-h-48 overflow-y-auto"></div>
                </div>
              </div>
              <div class="mt-4 hidden" id="uploadProgress">
                <div class="flex justify-between items-center text-sm mb-2">
                  <span id="uploadProgressStatus" class="text-gray-400 truncate mr-2">Uploading...</span>
                  <span id="uploadProgressPercent" class="text-primary font-medium">0%</span>
                </div>
                <div class="w-full bg-dark-700 rounded-full h-2.5">
                  <div id="uploadProgressBar" class="bg-primary h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
                <div id="uploadFilesList" class="mt-3 space-y-2 max-h-48 overflow-y-auto"></div>
              </div>
            </form>
          </div>
          <div class="flex justify-end gap-3 p-4 border-t border-gray-700">
            <button onclick="closeUploadModal()"
              class="px-4 py-2 bg-dark-700 hover:bg-dark-600 text-gray-300 rounded-lg transition-colors">Cancel</button>
            <button id="uploadButton"
              class="px-4 py-2 bg-primary hover:bg-blue-600 text-white rounded-lg transition-colors disabled:bg-gray-600 disabled:cursor-not-allowed"
              disabled>
              <i class="ti ti-upload mr-1.5"></i>Upload
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Upload Progress Bar -->
    <div id="bottomUploadBar" class="fixed bottom-0 left-0 right-0 bg-dark-800 border-t border-dark-600 z-40 hidden">
      <div class="flex items-center gap-3 px-4 py-2.5 max-w-screen-2xl mx-auto">
        <i class="ti ti-upload text-primary text-sm shrink-0"></i>
        <span class="text-sm text-gray-400 truncate flex-1 min-w-0" id="bottomUploadStatus">Uploading...</span>
        <div class="w-40 bg-dark-600 rounded-full h-1.5 shrink-0">
          <div id="bottomProgressBar" class="bg-primary h-1.5 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <span class="text-sm text-gray-300 shrink-0 w-10 text-right" id="bottomProgressPercent">0%</span>
        <button onclick="cancelActiveOperation()" class="text-red-400 hover:text-red-300 shrink-0" title="Cancel">
          <i class="ti ti-x text-sm"></i></button>
      </div>
    </div>

    <div id="cloudImportModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden modal-overlay overflow-y-auto">
      <div class="flex min-h-screen items-center justify-center p-4">
        <div id="cloudModalContent" class="bg-dark-800 rounded-lg shadow-xl w-full max-w-md">
          <div class="flex items-center justify-between p-4 border-b border-gray-700">
            <h3 id="cloudModalTitle" class="text-lg font-semibold">Import from Cloud</h3>
            <button id="closeCloudBtn" class="text-gray-400 hover:text-white">
              <i class="ti ti-x text-xl"></i>
            </button>
          </div>
          <div id="cloudModalBody"></div>
        </div>
      </div>
    </div>

    <div id="toast"
      class="fixed top-16 right-4 bg-dark-800 text-white px-4 py-3 rounded-lg shadow-lg z-50 hidden flex items-center">
      <i id="toast-icon" class="mr-2"></i>
      <span id="toast-message"></span>
    </div>

    <script>
      // ============================================================
      // STATE
      // ============================================================
      let currentView = 'grid';
      let currentUploadType = 'video';
      let serverDiskFree = Infinity;
      let serverDiskTotal = Infinity;
      let serverDiskUsed = 0;
      const DISK_SAFETY_BUFFER = 100 * 1024 * 1024;

      // Folder state
      let allFolders = [];          // { id, name, parent_id }
      let currentFolderId = null;   // null = root
      let folderPath = [];          // breadcrumb stack: [{id, name}]
      let selectedMoveTarget = null; // folder id chosen in move modal

      // Selection state
      let selectedFileIds = new Set();

      loadDiskUsage();
      loadFolders();

      function reloadKeepingFolder() {
        if (currentFolderId !== null) {
          sessionStorage.setItem('restoreFolder', String(currentFolderId));
        } else {
          sessionStorage.removeItem('restoreFolder');
        }
        window.location.reload();
      }

      // ============================================================
      // DISK USAGE
      // ============================================================
      async function loadDiskUsage() {
        try {
          const response = await fetch('/api/system/disk-space');
          const data = await response.json();
          if (data.success) {
            serverDiskFree = data.free;
            serverDiskTotal = data.total;
            serverDiskUsed = data.used;
            updateDiskUsageDisplay();
          }
        } catch (error) { console.error('Error loading disk space:', error); }
      }

      function updateDiskUsageDisplay() {
        const infoDesktop = document.getElementById('diskUsageInfoDesktop');
        const textDesktop = document.getElementById('diskUsageTextDesktop');
        const infoMobile = document.getElementById('diskUsageInfoMobile');
        const textMobile = document.getElementById('diskUsageTextMobile');
        if (serverDiskTotal !== Infinity) {
          const displayText = `${formatFileSize(serverDiskUsed)} / ${formatFileSize(serverDiskTotal)} (${formatFileSize(serverDiskFree)} free)`;
          textDesktop.textContent = displayText;
          textMobile.textContent = displayText;
          const isMobile = window.innerWidth < 768;
          if (isMobile) { infoDesktop.classList.add('hidden'); infoMobile.classList.remove('hidden'); }
          else { infoDesktop.classList.remove('hidden'); infoMobile.classList.add('hidden'); }
        } else { infoDesktop.classList.add('hidden'); infoMobile.classList.add('hidden'); }
      }
      window.addEventListener('resize', updateDiskUsageDisplay);

      function checkDiskLimit(fileSize) { return serverDiskFree >= (fileSize + DISK_SAFETY_BUFFER); }
      function getRemainingSpace() { return Math.max(0, serverDiskFree - DISK_SAFETY_BUFFER); }

      function formatFileSize(bytes) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
      }

      // ============================================================
      // TOAST
      // ============================================================
      function showToast(type, message) {
        const toast = document.getElementById('toast');
        const toastIcon = document.getElementById('toast-icon');
        const toastMessage = document.getElementById('toast-message');
        if (type === 'success') {
          toastIcon.className = 'ti ti-check text-green-400 text-xl mr-2 font-loaded';
          toast.className = 'fixed top-16 right-4 bg-dark-800 text-white px-4 py-3 rounded-lg shadow-lg z-50 flex items-center border-l-4 border-green-400';
        } else if (type === 'error') {
          toastIcon.className = 'ti ti-x text-red-400 text-xl mr-2 font-loaded';
          toast.className = 'fixed top-16 right-4 bg-dark-800 text-white px-4 py-3 rounded-lg shadow-lg z-50 flex items-center border-l-4 border-red-400';
        } else if (type === 'warning') {
          toastIcon.className = 'ti ti-alert-triangle text-yellow-400 text-xl mr-2 font-loaded';
          toast.className = 'fixed top-16 right-4 bg-dark-800 text-white px-4 py-3 rounded-lg shadow-lg z-50 flex items-center border-l-4 border-yellow-400';
        }
        toastMessage.textContent = message;
        toast.classList.remove('hidden');
        setTimeout(() => toast.classList.add('hidden'), 3000);
      }

      // ============================================================
      // FOLDER API CALLS
      // ============================================================
      async function loadFolders() {
        try {
          const res = await fetch('/api/folders');
          const data = await res.json();
          if (data.success) {
            allFolders = data.folders || [];
            const restoreId = sessionStorage.getItem('restoreFolder');
            if (restoreId) {
              sessionStorage.removeItem('restoreFolder');
              const folderId = isNaN(restoreId) ? restoreId : Number(restoreId);
              const folder = allFolders.find(f => String(f.id) === String(folderId));
              if (folder) { navigateToFolder(folderId); return; }
            }
            renderFolders();
            renderBreadcrumb();
          }
        } catch (e) { console.error('Error loading folders:', e); }
      }

      // Folders visible in current level
      function getCurrentFolders() {
        return allFolders.filter(f => (f.parent_id || null) === currentFolderId);
      }

      function renderFolders() {
        const folders = getCurrentFolders();
        renderFolderGrid(folders);
        renderFolderList(folders);
        renderCurrentFiles();
      }

      function renderFolderGrid(folders) {
        const container = document.getElementById('folderGridContainer');
        container.innerHTML = '';
        // Back button when inside a folder
        if (currentFolderId !== null) {
          const back = document.createElement('div');
          back.className = 'group bg-dark-700 rounded-lg border border-transparent hover:border-gray-600 hover:bg-dark-600 transition-all cursor-pointer flex items-center gap-2 px-3 py-2';
          back.innerHTML = `<i class="ti ti-arrow-back-up text-base text-gray-400 group-hover:text-white transition-colors flex-shrink-0"></i><span class="text-xs text-gray-400 group-hover:text-white truncate">..</span>`;
          back.onclick = () => navigateUp();
          container.appendChild(back);
        }
        folders.forEach(folder => container.appendChild(createFolderCard(folder)));
      }

      function renderFolderList(folders) {
        const container = document.getElementById('folderListContainer');
        container.innerHTML = '';
        if (currentFolderId !== null) {
          const backRow = document.createElement('div');
          backRow.className = 'flex items-center gap-3 px-4 py-2 hover:bg-dark-700 rounded-lg cursor-pointer text-gray-400 hover:text-white transition-colors mb-1';
          backRow.innerHTML = `<i class="ti ti-arrow-back-up"></i><span class="text-sm">..</span>`;
          backRow.onclick = () => navigateUp();
          container.appendChild(backRow);
        }
        folders.forEach(folder => {
          const row = document.createElement('div');
          row.className = 'flex items-center justify-between px-4 py-2 hover:bg-dark-700 rounded-lg cursor-pointer group mb-1';
          row.addEventListener('click', () => navigateToFolder(folder.id));
          row.innerHTML = `
            <div class="flex items-center gap-3">
              <i class="ti ti-folder text-yellow-400 text-xl"></i>
              <span class="text-sm font-medium">${folder.name}</span>
            </div>
            <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-white transition-colors" title="Rename"
                onclick="event.stopPropagation(); openRenameFolderModal('${folder.id}', '${folder.name.replace(/'/g,"\\'")}')">
                <i class="ti ti-pencil text-sm"></i>
              </button>
              <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-red-400 transition-colors" title="Delete folder"
                onclick="event.stopPropagation(); confirmDeleteFolder('${folder.id}', '${folder.name.replace(/'/g,"\\'")}')">
                <i class="ti ti-trash text-sm"></i>
              </button>
            </div>
          `;
          container.appendChild(row);
        });
      }

      function createFolderCard(folder) {
        const card = document.createElement('div');
        card.className = 'group bg-dark-700 rounded-lg border border-transparent hover:border-yellow-500/40 hover:bg-dark-600 transition-all cursor-pointer relative flex items-center gap-2 px-3 py-2';
        card.innerHTML = `
          <i class="ti ti-folder text-yellow-400 text-lg group-hover:text-yellow-300 transition-colors flex-shrink-0"></i>
          <span class="text-xs font-medium truncate flex-1">${folder.name}</span>
          <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
            <button class="w-5 h-5 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-dark-500 transition-colors" title="Rename"
              onclick="event.stopPropagation(); openRenameFolderModal('${folder.id}', '${folder.name.replace(/'/g,"\\'")}')">
              <i class="ti ti-pencil text-xs"></i>
            </button>
            <button class="w-5 h-5 flex items-center justify-center rounded text-gray-400 hover:text-red-400 hover:bg-dark-500 transition-colors" title="Delete"
              onclick="event.stopPropagation(); confirmDeleteFolder('${folder.id}', '${folder.name.replace(/'/g,"\\'")}')">
              <i class="ti ti-trash text-xs"></i>
            </button>
          </div>
        `;
        card.addEventListener('click', () => navigateToFolder(folder.id));
        return card;
      }

      // Show/hide file items based on current folder
      function renderCurrentFiles() {
        const allGridItems = document.querySelectorAll('.file-item');
        const allListItems = document.querySelectorAll('.file-item-row');
        allGridItems.forEach(item => {
          const itemFolder = item.dataset.folder || '';
          const match = currentFolderId === null ? itemFolder === '' : itemFolder === String(currentFolderId);
          item.style.display = match ? '' : 'none';
        });
        allListItems.forEach(item => {
          const itemFolder = item.dataset.folder || '';
          const match = currentFolderId === null ? itemFolder === '' : itemFolder === String(currentFolderId);
          item.style.display = match ? '' : 'none';
        });
        // Rerun pagination/filter
        filterAndSort();
      }

      // ============================================================
      // NAVIGATION
      // ============================================================
      function navigateToFolder(folderId) {
        if (folderId === null) {
          currentFolderId = null;
          folderPath = [];
        } else {
          const folder = allFolders.find(f => f.id === folderId || f.id === String(folderId));
          if (!folder) return;
          // Check if already in path (going back to ancestor)
          const idx = folderPath.findIndex(p => String(p.id) === String(folderId));
          if (idx >= 0) {
            folderPath = folderPath.slice(0, idx + 1);
          } else {
            folderPath.push({ id: folder.id, name: folder.name });
          }
          currentFolderId = folderId;
        }
        renderBreadcrumb();
        renderFolders();
      }

      function navigateUp() {
        if (folderPath.length === 0) return;
        folderPath.pop();
        currentFolderId = folderPath.length > 0 ? folderPath[folderPath.length - 1].id : null;
        renderBreadcrumb();
        renderFolders();
      }

      function renderBreadcrumb() {
        const bc = document.getElementById('breadcrumb');
        // Keep first root button, rebuild the rest
        bc.innerHTML = `
          <button onclick="navigateToFolder(null)" class="hover:text-white transition-colors flex items-center gap-1">
            <i class="ti ti-home text-xs"></i><span>Root</span>
          </button>
        `;
        folderPath.forEach((seg, i) => {
          const sep = document.createElement('span');
          sep.className = 'text-gray-600';
          sep.textContent = '/';
          bc.appendChild(sep);
          const btn = document.createElement('button');
          btn.className = i === folderPath.length - 1
            ? 'text-white font-medium'
            : 'hover:text-white transition-colors';
          btn.textContent = seg.name;
          btn.onclick = () => navigateToFolder(seg.id);
          bc.appendChild(btn);
        });
      }

      // ============================================================
      // CREATE FOLDER
      // ============================================================
      function openCreateFolderModal() {
        document.getElementById('newFolderName').value = '';
        const modal = document.getElementById('createFolderModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => document.getElementById('newFolderName').focus(), 100);
      }
      function closeCreateFolderModal() {
        const modal = document.getElementById('createFolderModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
      document.getElementById('newFolderName').addEventListener('keydown', e => { if (e.key === 'Enter') createFolder(); });

      async function createFolder() {
        const name = document.getElementById('newFolderName').value.trim();
        if (!name) { showToast('error', 'Please enter a folder name'); return; }
        try {
          const res = await fetch('/api/folders', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, parent_id: currentFolderId })
          });
          const data = await res.json();
          if (data.success) {
            allFolders.push(data.folder);
            closeCreateFolderModal();
            renderFolders();
            showToast('success', `Folder "${name}" created`);
          } else {
            showToast('error', data.error || 'Failed to create folder');
          }
        } catch (e) {
          showToast('error', 'Error creating folder');
        }
      }

      // ============================================================
      // RENAME FOLDER
      // ============================================================
      function openRenameFolderModal(folderId, currentName) {
        document.getElementById('renameFolderId').value = folderId;
        document.getElementById('renameFolderName').value = currentName;
        const modal = document.getElementById('renameFolderModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
          const inp = document.getElementById('renameFolderName');
          inp.focus(); inp.select();
        }, 100);
      }
      function closeRenameFolderModal() {
        const modal = document.getElementById('renameFolderModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
      document.getElementById('renameFolderName').addEventListener('keydown', e => { if (e.key === 'Enter') renameFolder(); });

      async function renameFolder() {
        const folderId = document.getElementById('renameFolderId').value;
        const name = document.getElementById('renameFolderName').value.trim();
        if (!name) { showToast('error', 'Please enter a folder name'); return; }
        try {
          const res = await fetch(`/api/folders/${folderId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name })
          });
          const data = await res.json();
          if (data.success) {
            const f = allFolders.find(x => String(x.id) === String(folderId));
            if (f) f.name = name;
            // Update breadcrumb if in path
            const seg = folderPath.find(p => String(p.id) === String(folderId));
            if (seg) seg.name = name;
            closeRenameFolderModal();
            renderFolders();
            renderBreadcrumb();
            showToast('success', 'Folder renamed');
          } else {
            showToast('error', data.error || 'Failed to rename folder');
          }
        } catch (e) {
          showToast('error', 'Error renaming folder');
        }
      }

      // ============================================================
      // DELETE FOLDER
      // ============================================================
      async function confirmDeleteFolder(folderId, folderName) {
        const result = await createModalDialog({
          type: 'danger',
          icon: 'ti-trash',
          title: 'Delete Folder',
          message: `Delete folder "${folderName}" and ALL its contents? This cannot be undone.`,
          confirmText: 'Delete',
          confirmClass: 'bg-red-500 hover:bg-red-600'
        });
        if (!result.confirmed) return;
        try {
          const res = await fetch(`/api/folders/${folderId}`, { method: 'DELETE' });
          const data = await res.json();
          if (data.success) {
            allFolders = allFolders.filter(f => String(f.id) !== String(folderId));
            // If we were inside this folder, go back to root
            if (String(currentFolderId) === String(folderId)) {
              currentFolderId = null;
              folderPath = [];
              renderBreadcrumb();
            }
            renderFolders();
            showToast('success', `Folder "${folderName}" deleted`);
            setTimeout(() => window.location.reload(), 1000);
          } else {
            showToast('error', data.error || 'Failed to delete folder');
          }
        } catch (e) {
          showToast('error', 'Error deleting folder');
        }
      }

      // ============================================================
      // MOVE / COPY FILE
      // ============================================================
      function openMoveModal(fileId, fileTitle, action) {
        document.getElementById('moveFileId').value = fileId;
        document.getElementById('moveAction').value = action;
        document.getElementById('moveModalTitle').innerHTML =
          action === 'move'
            ? `<i class="ti ti-folder-symlink text-primary mr-2"></i>Move: ${fileTitle}`
            : `<i class="ti ti-copy text-green-400 mr-2"></i>Copy: ${fileTitle}`;
        selectedMoveTarget = undefined; // undefined = belum dipilih

        const list = document.getElementById('folderPickerList');
        list.innerHTML = '';

        // Root option
        const rootOpt = createFolderOption(null, '/ Root');
        list.appendChild(rootOpt);

        // All folders (flat list, indented by depth)
        function addFolderOptions(parentId, depth) {
          allFolders.filter(f => (f.parent_id || null) === parentId).forEach(f => {
            list.appendChild(createFolderOption(f.id, f.name, depth));
            addFolderOptions(f.id, depth + 1);
          });
        }
        addFolderOptions(null, 0);

        const modal = document.getElementById('moveModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }

      function createFolderOption(folderId, name, depth = 0) {
        const div = document.createElement('div');
        div.className = 'flex items-center gap-2 px-3 py-2 rounded-lg cursor-pointer hover:bg-dark-600 transition-colors border border-transparent';
        div.style.paddingLeft = `${12 + depth * 16}px`;
        div.dataset.folderId = folderId === null ? '' : folderId;
        div.innerHTML = `
          <i class="ti ${folderId === null ? 'ti-home' : 'ti-folder'} ${folderId === null ? 'text-gray-400' : 'text-yellow-400'} text-sm"></i>
          <span class="text-sm">${name}</span>
        `;
        div.addEventListener('click', () => {
          document.querySelectorAll('#folderPickerList > div').forEach(d => {
            d.classList.remove('border-primary', 'bg-primary/10');
            d.classList.add('border-transparent');
          });
          div.classList.add('border-primary', 'bg-primary/10');
          div.classList.remove('border-transparent');
          selectedMoveTarget = folderId;
        });
        return div;
      }

      function closeMoveModal() {
        const modal = document.getElementById('moveModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        // undefined = belum dipilih, null = root (valid), <id> = folder tertentu (valid)
        selectedMoveTarget = undefined;
        // Reset ke handler single-file
        document.getElementById('moveConfirmBtn').onclick = confirmMoveFile;
      }

      async function confirmMoveFile() {
        if (selectedMoveTarget === undefined) {
          showToast('error', 'Please select a destination folder'); return;
        }

        // Capture dulu sebelum closeMoveModal() me-reset selectedMoveTarget
        const targetFolderId = selectedMoveTarget;
        const fileId = document.getElementById('moveFileId').value;
        const action = document.getElementById('moveAction').value;
        const endpoint = action === 'move' ? `/api/videos/${fileId}/move` : `/api/videos/${fileId}/copy`;

        closeMoveModal();

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ folder_id: targetFolderId })
          });
          const data = await res.json();
          if (data.success) {
            showToast('success', action === 'move' ? 'File moved successfully' : 'File copied successfully');
            setTimeout(() => reloadKeepingFolder(), 1000);
          } else {
            showToast('error', data.error || `Failed to ${action} file`);
          }
        } catch (e) {
          showToast('error', `Error during ${action}`);
        }
      }

      // ============================================================
      // CHECKBOX & BULK DELETE
      // ============================================================
      function handleFileClick(event, fileId, fileTitle, mediaType) {
        // If clicked on a checkbox or button, don't play
        if (event.target.closest('.checkbox-wrapper') || event.target.closest('button')) return;
        playMedia(fileId, fileTitle, mediaType);
      }

      function handleCheckboxChange(checkbox) {
        const fileId = checkbox.dataset.id;
        const isChecked = checkbox.checked;
        // Sync pasangan checkbox (grid ↔ list) dengan data-id sama
        document.querySelectorAll(`.file-checkbox[data-id="${fileId}"]`).forEach(cb => {
          cb.checked = isChecked;
          const card = cb.closest('.file-item') || cb.closest('.file-item-row');
          if (isChecked) {
            if (card) card.classList.add('ring-2', 'ring-primary');
            const wrapper = cb.closest('.checkbox-wrapper');
            if (wrapper) wrapper.style.opacity = '1';
          } else {
            if (card) card.classList.remove('ring-2', 'ring-primary');
            const wrapper = cb.closest('.checkbox-wrapper');
            if (wrapper) wrapper.style.opacity = '';
          }
        });
        if (isChecked) selectedFileIds.add(fileId);
        else selectedFileIds.delete(fileId);
        updateBulkBar();
      }

      function selectAll() {
        document.querySelectorAll('.file-item, .file-item-row').forEach(card => {
          // Hanya item yang visible (tidak di-hide oleh pagination/filter)
          if (card.style.display === 'none') return;
          const cb = card.querySelector('.file-checkbox');
          if (!cb || cb.checked) return;
          cb.checked = true;
          handleCheckboxChange(cb);
        });
      }

      function updateBulkBar() {
        const bar = document.getElementById('bulkActionBar');
        const countEl = document.getElementById('selectedCount');
        const selectAllCb = document.getElementById('selectAllCheckbox');
        if (selectedFileIds.size > 0) {
          bar.classList.remove('hidden');
          bar.classList.add('flex');
          countEl.textContent = `${selectedFileIds.size} selected`;
          if (selectAllCb) selectAllCb.checked = true;
        } else {
          bar.classList.add('hidden');
          bar.classList.remove('flex');
          if (selectAllCb) selectAllCb.checked = false;
        }
      }

      function clearSelection() {
        selectedFileIds.clear();
        document.querySelectorAll('.file-checkbox').forEach(cb => {
          cb.checked = false;
          const card = cb.closest('.file-item') || cb.closest('.file-item-row');
          if (card) card.classList.remove('ring-2', 'ring-primary');
          const wrapper = cb.closest('.checkbox-wrapper');
          if (wrapper) wrapper.style.opacity = '';
        });
        const selectAllCb = document.getElementById('selectAllCheckbox');
        if (selectAllCb) selectAllCb.checked = false;
        updateBulkBar();
      }

      async function deleteSelected() {
        if (selectedFileIds.size === 0) return;
        const count = selectedFileIds.size;
        const result = await createModalDialog({
          type: 'danger',
          icon: 'ti-trash',
          title: 'Delete Selected Files',
          message: `Delete ${count} selected file${count > 1 ? 's' : ''}? This action cannot be undone.`,
          confirmText: 'Delete All',
          confirmClass: 'bg-red-500 hover:bg-red-600'
        });
        if (!result.confirmed) return;

        let successCount = 0;
        let failCount = 0;
        for (const fileId of selectedFileIds) {
          try {
            const res = await fetch(`/api/videos/${fileId}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) successCount++;
            else failCount++;
          } catch (e) { failCount++; }
        }

        if (failCount === 0) showToast('success', `${successCount} file${successCount > 1 ? 's' : ''} deleted`);
        else showToast('warning', `${successCount} deleted, ${failCount} failed`);
        setTimeout(() => reloadKeepingFolder(), 1000);
      }

      // ============================================================
      // BULK MOVE / COPY SELECTED
      // ============================================================

      function bulkMoveSelected() {
        if (selectedFileIds.size === 0) return;
        _openBulkFolderPicker('move');
      }

      function bulkCopySelected() {
        if (selectedFileIds.size === 0) return;
        _openBulkFolderPicker('copy');
      }

      /**
       * Reuse openMoveModal dengan file pertama sebagai "dummy" agar
       * folder picker ter-render identik, lalu override judul + confirm handler.
       */
      function _openBulkFolderPicker(action) {
        const count = selectedFileIds.size;
        const firstId = [...selectedFileIds][0];

        // Pakai openMoveModal yang sudah terbukti jalan
        openMoveModal(firstId, `${count} file${count > 1 ? 's' : ''}`, action);

        // Override judul setelah modal dibuka
        const isCopy = action === 'copy';
        document.getElementById('moveModalTitle').innerHTML = isCopy
          ? `<i class="ti ti-copy text-green-400 mr-2"></i>Copy ${count} file${count > 1 ? 's' : ''} to...`
          : `<i class="ti ti-folder-symlink text-primary mr-2"></i>Move ${count} file${count > 1 ? 's' : ''} to...`;

        // Override confirm button ke handler bulk
        document.getElementById('moveConfirmBtn').onclick = () => _executeBulkAction(action);
      }

      async function _executeBulkAction(action) {
        if (selectedMoveTarget === undefined) {
          showToast('error', 'Please select a destination folder');
          return;
        }

        // Capture dulu sebelum closeMoveModal() me-reset selectedMoveTarget
        const targetFolderId = selectedMoveTarget;
        const ids = [...selectedFileIds];
        const count = ids.length;
        const verb = action === 'move' ? 'moved' : 'copied';

        closeMoveModal();
        showToast('warning', `Processing ${count} file${count > 1 ? 's' : ''}...`);

        let successCount = 0;
        let failCount = 0;

        for (const fileId of ids) {
          try {
            const res = await fetch(`/api/videos/${fileId}/${action}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ folder_id: targetFolderId })
            });
            const data = await res.json();
            if (data.success) successCount++;
            else failCount++;
          } catch (e) { failCount++; }
        }

        if (failCount === 0) {
          showToast('success', `${successCount} file${successCount > 1 ? 's' : ''} ${verb} successfully`);
        } else {
          showToast('warning', `${successCount} ${verb}, ${failCount} failed`);
        }

        setTimeout(() => reloadKeepingFolder(), 1000);
      }

