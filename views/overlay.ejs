<% layout('layout') -%>
  <div class="container mt-4">
    <h4 class="mb-4"><i class="bi bi-image"></i> Pengaturan Overlay Logo</h4>

    <div class="row g-4">
      <!-- Preview Panel -->
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">Preview Posisi</div>
          <div class="card-body p-0">
            <div id="preview-area" style="position:relative; width:100%; aspect-ratio:16/9; background:#111; overflow:hidden; border-radius:0 0 4px 4px;">
              <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#444; font-size:12px;">Area Video (16:9)</div>
              <img id="preview-logo" src="<%= settings.image_path ? '/' + settings.image_path : '' %>"
                style="position:absolute; display:<%= settings.image_path ? 'block' : 'none' %>; cursor:move;
                  left:<%= ((settings.position_x || 10) / 1920 * 100).toFixed(2) %>%;
                  top:<%= ((settings.position_y || 10) / 1080 * 100).toFixed(2) %>%;
                  width:<%= ((settings.width || 150) / 1920 * 100).toFixed(2) %>%;
                  opacity:<%= settings.opacity || 1 %>;"
                id="draggable-logo" draggable="false">
            </div>
          </div>
        </div>

        <!-- Upload -->
        <div class="card mt-3">
          <div class="card-body">
            <label class="form-label fw-semibold">Upload Logo (PNG/WebP transparan)</label>
            <input type="file" class="form-control" id="logo-file" accept=".png,.jpg,.jpeg,.webp,.gif">
            <% if (settings.image_path) { %>
              <button class="btn btn-sm btn-outline-danger mt-2" onclick="deleteLogo()">
                <i class="bi bi-trash"></i> Hapus Logo
              </button>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Settings Panel -->
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">Pengaturan</div>
          <div class="card-body">
            <div class="form-check form-switch mb-3">
              <input class="form-check-input" type="checkbox" id="enabled" <%= settings.enabled ? 'checked' : '' %>>
              <label class="form-check-label" for="enabled">Aktifkan Overlay</label>
            </div>

            <label class="form-label">Posisi X (px dari kiri, 1920px base)</label>
            <input type="range" class="form-range" id="pos-x" min="0" max="1820" 
              value="<%= settings.position_x || 10 %>" oninput="updatePreview()">
            <div class="d-flex justify-content-between mb-3">
              <small class="text-muted">Kiri</small>
              <span id="pos-x-val" class="badge bg-secondary"><%= settings.position_x || 10 %>px</span>
              <small class="text-muted">Kanan</small>
            </div>

            <label class="form-label">Posisi Y (px dari atas, 1080px base)</label>
            <input type="range" class="form-range" id="pos-y" min="0" max="980"
              value="<%= settings.position_y || 10 %>" oninput="updatePreview()">
            <div class="d-flex justify-content-between mb-3">
              <small class="text-muted">Atas</small>
              <span id="pos-y-val" class="badge bg-secondary"><%= settings.position_y || 10 %>px</span>
              <small class="text-muted">Bawah</small>
            </div>

            <label class="form-label">Ukuran Lebar Logo</label>
            <input type="range" class="form-range" id="logo-w" min="20" max="600"
              value="<%= settings.width || 150 %>" oninput="updatePreview()">
            <div class="d-flex justify-content-between mb-3">
              <small class="text-muted">Kecil</small>
              <span id="logo-w-val" class="badge bg-secondary"><%= settings.width || 150 %>px</span>
              <small class="text-muted">Besar</small>
            </div>

            <label class="form-label">Opacity / Transparansi</label>
            <input type="range" class="form-range" id="opacity" min="0.05" max="1" step="0.05"
              value="<%= settings.opacity || 1 %>" oninput="updatePreview()">
            <div class="d-flex justify-content-between mb-4">
              <small class="text-muted">Transparan</small>
              <span id="opacity-val" class="badge bg-secondary"><%= Math.round((settings.opacity || 1) * 100) %>%</span>
              <small class="text-muted">Solid</small>
            </div>

            <button class="btn btn-primary w-100" onclick="saveSettings()">
              <i class="bi bi-save"></i> Simpan Pengaturan
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function updatePreview() {
      const x = parseInt(document.getElementById('pos-x').value);
      const y = parseInt(document.getElementById('pos-y').value);
      const w = parseInt(document.getElementById('logo-w').value);
      const opacity = parseFloat(document.getElementById('opacity').value);
      const area = document.getElementById('preview-area');
      const logo = document.getElementById('preview-logo');
      
      const areaW = area.offsetWidth;
      const areaH = area.offsetHeight;
      
      logo.style.left = (x / 1920 * 100).toFixed(2) + '%';
      logo.style.top = (y / 1080 * 100).toFixed(2) + '%';
      logo.style.width = (w / 1920 * 100).toFixed(2) + '%';
      logo.style.opacity = opacity;
      
      document.getElementById('pos-x-val').textContent = x + 'px';
      document.getElementById('pos-y-val').textContent = y + 'px';
      document.getElementById('logo-w-val').textContent = w + 'px';
      document.getElementById('opacity-val').textContent = Math.round(opacity * 100) + '%';
    }

    function saveSettings() {
      fetch('/overlay/settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          enabled: document.getElementById('enabled').checked ? '1' : '0',
          position_x: document.getElementById('pos-x').value,
          position_y: document.getElementById('pos-y').value,
          width: document.getElementById('logo-w').value,
          opacity: document.getElementById('opacity').value
        })
      })
      .then(r => r.json())
      .then(d => {
        if (d.success) showToast('Pengaturan disimpan!', 'success');
      });
    }

    document.getElementById('logo-file').addEventListener('change', function() {
      const fd = new FormData();
      fd.append('logo', this.files[0]);
      fetch('/overlay/upload', { method: 'POST', body: fd })
        .then(r => r.json())
        .then(d => {
          if (d.success) {
            const logo = document.getElementById('preview-logo');
            logo.src = d.path + '?t=' + Date.now();
            logo.style.display = 'block';
            showToast('Logo berhasil diupload!', 'success');
          }
        });
    });

    function deleteLogo() {
      if (!confirm('Hapus logo overlay?')) return;
      fetch('/overlay/logo', { method: 'DELETE' })
        .then(r => r.json())
        .then(() => location.reload());
    }

    function showToast(msg, type = 'success') {
      // Sesuaikan dengan toast/notification yang sudah ada di project kamu
      alert(msg);
    }
  </script>
